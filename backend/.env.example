# =============================================================================
# AI Resume Analyzer - Environment Configuration
# =============================================================================
# This file contains settings for the backend API.
# Copy this file to .env and adjust values as needed.
#
# Usage: The app automatically loads these settings on startup.
# =============================================================================

# -----------------------------------------------------------------------------
# AI Service Configuration
# -----------------------------------------------------------------------------
# This is where Daniyal's AI service will be running.
# Your backend will call this URL to get resume analysis.

AI_SERVICE_URL=http://localhost:8001


# -----------------------------------------------------------------------------
# API Server Configuration
# -----------------------------------------------------------------------------
# These settings control how your backend API runs.

# Host address: 0.0.0.0 means accessible from all network interfaces
# Use 127.0.0.1 for local-only access
API_HOST=0.0.0.0

# Port number: The API will be available at http://localhost:8000
# Change this if port 8000 is already in use
API_PORT=8000

# Debug mode: Set to 'true' for development (enables auto-reload)
# Set to 'false' for production
DEBUG=true
